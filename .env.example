TZ=Europe/Berlin

KAI_COCKPIT_SECRET=change-me-openssl-rand-hex-32
# KAI_COCKPIT_ESCALATION_SECRET=change-me-openssl-rand-hex-32
KAI_PUBLIC_URL=http://localhost:8080
KAI_CONTACT_EMAIL=hello@meetk.ai
KAI_COCKPIT_DB=sqlite:///data/cockpit.db
KAI_CONFIGS_DIR=data/configs/cockpit
KAI_LOG_DIR=/app/data/logs
# KAI_COCKPIT_AUTO_APPROVE_LOGIN=true
# KAI_COCKPIT_TESTING=true
KAI_WAHA_WEBHOOK_PORT_RANGE=8100-8199

KAI_SMTP_HOST=mailpit
KAI_SMTP_PORT=1025
KAI_SMTP_FROM=support@meetk.ai
# KAI_SMTP_USER=resend
# KAI_SMTP_PASSWORD=re_your_api_key

KAI_CREDENTIAL_ENCRYPTION_KEY=change-me-openssl-rand-hex-32
KAI_CREDENTIAL_KEY_VERSION=v1

KAI_WAHA_URL=http://waha:3000
KAI_WAHA_API_KEY=your-waha-api-key
KAI_WAHA_HMAC_KEY=random-hmac-key-for-waha-settings-validation
KAI_WAHA_WEBHOOK_PUBLIC_HOST=cockpit
# KAI_WAHA_HMAC_ALGORITHM=sha512
# KAI_WAHA_WHISPER_LANGUAGE=auto
# KAI_WAHA_WHISPER_SERVER_HOST=127.0.0.1
# KAI_WAHA_WHISPER_SERVER_PORT=8787
# KAI_WAHA_WHISPER_SERVER_THREADS=4
# KAI_WAHA_WHISPER_MODEL_PATH=models/whisper/ggml-base.bin
# KAI_WAHA_KOKORO_ENABLED=true
# KAI_WAHA_KOKORO_SERVER_HOST=127.0.0.1
# KAI_WAHA_KOKORO_SERVER_PORT=8788
# KAI_WAHA_KOKORO_MODEL_PATH=models/kokoro/kokoro-v1.0.int8.onnx
# KAI_WAHA_KOKORO_VOICES_PATH=models/kokoro/voices-v1.0.bin
# KAI_WAHA_KOKORO_VOICE=af_heart
# KAI_WAHA_KOKORO_LANG=
# KAI_WAHA_KOKORO_SPEED=1.0
# KAI_WAHA_KOKORO_MAX_CHARS=300
# KAI_WAHA_MEDIA_READY_TIMEOUT=30.0

KAI_LLM_API_BASE=https://api.openai.com/v1
KAI_LLM_API_KEY=sk-your-api-key
KAI_LLM_MODEL=gpt-4o-mini
# KAI_LLM_ENABLE_THINKING=false

KAI_AGENT_HISTORY_FOLDER=/app/data
# KAI_AGENT_MAX_HISTORY_MESSAGES=100
# KAI_AGENT_MAX_HISTORY_CHARS=12000
# KAI_AGENT_MAX_CONVERSATIONS=256
# KAI_AGENT_LANGUAGE=English
# KAI_AGENT_LANGUAGE_EXPLICIT=false
# KAI_TASKS_ENABLED=true
# KAI_TASKS_POLL_INTERVAL_SECONDS=5.0
KAI_TASKS_FOLDER=/app/data
KAI_ESCALATIONS_FOLDER=/app/data

KAI_BRAIN_BASE_URL=http://morphik:8000
KAI_BRAIN_MORPHIK_TOKEN=your-morphik-bearer-token
KAI_BRAIN_CRAWLER_URL=http://crawl4ai:11235
KAI_BRAIN_CRAWL4AI_TOKEN=your-crawl4ai-token
# KAI_BRAIN_WORKSPACE=default
# KAI_BRAIN_INSTRUCTION=one trigger per line
# KAI_BRAIN_MANDATORY=false
# KAI_BRAIN_MANDATORY_TEMPERATURE=0.0
# KAI_BRAIN_CRAWL_MAX_DEPTH=1
# KAI_BRAIN_CRAWL_MAX_PAGES=25

# Morphik JWT secret (used by the morphik container to sign/verify tokens).
# Generate a real one: openssl rand -hex 32
KAI_BRAIN_MORPHIK_JWT_SECRET=change-me-openssl-rand-hex-32
# Password the morphik container requires on /local/generate_uri (its
# LOCAL_URI_PASSWORD). The cockpit entrypoint sends this to mint a bearer
# token on first boot. Generate: openssl rand -hex 16
KAI_BRAIN_MORPHIK_LOCAL_PASSWORD=change-me-openssl-rand-hex-16

# KAI_SMTP_TOOL_HOST=smtp.example.com
# KAI_SMTP_TOOL_PORT=587
# KAI_SMTP_TOOL_USERNAME=user
# KAI_SMTP_TOOL_PASSWORD=password
# KAI_SMTP_TOOL_FROM_ADDRESS=user@example.com
# KAI_SMTP_TOOL_USE_TLS=true
# KAI_SMTP_TOOL_INSTRUCTION=one trigger per line

# KAI_SQL_DSN=postgresql://user:pass@host/db
# KAI_SQL_INSTRUCTION=one trigger per line
# KAI_SQL_ROW_LIMIT=100

# KAI_EMAIL_MAX_ATTACHMENT_BYTES=10485760

WAHA_API_KEY=your-waha-api-key
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change-me
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=change-me
WAHA_DASHBOARD_ENABLED=True
WHATSAPP_SWAGGER_ENABLED=True
WHATSAPP_DEFAULT_ENGINE=WEBJS
WAHA_NAMESPACE=all
WAHA_BASE_URL=http://waha:3000
WAHA_LOG_FORMAT=JSON
WAHA_LOG_LEVEL=debug
WAHA_PRINT_QR=False
WAHA_MEDIA_STORAGE=LOCAL
WHATSAPP_FILES_LIFETIME=0
WHATSAPP_FILES_FOLDER=/app/.media
WHATSAPP_API_SCHEMA=http
WHATSAPP_API_HOSTNAME=localhost
WHATSAPP_API_PORT=3000
WAHA_APPS_ENABLED=True
REDIS_URL=redis://:redis@redis:6379

OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# Morphik LLM/embedding model config lives in docker/morphik.toml (mounted
# into the morphik container), not env vars.

# KAI_WHISPER_VERSION=latest
