# --- General ------------------------------------------------------------------
TZ=Europe/Berlin

# --- Cockpit (the management UI + bot spawner) --------------------------------
# Session cookie signing secret (required). Random, keep secret.
#   openssl rand -hex 32
KAI_COCKPIT_SECRET=change-me-to-a-random-string

# Public base URL the cockpit uses when minting magic-link emails. For local
# dev this is the host-mapped port; in production set it to the real public
# hostname (e.g. https://meetk.ai).
KAI_PUBLIC_URL=http://localhost:8080

# Contact email shown on the landing/login pages.
KAI_CONTACT_EMAIL=hello@meetk.ai

# Cockpit SQLite database path (in-container). Pinned to the data volume.
KAI_COCKPIT_DB=sqlite:///data/cockpit.db

# Where the cockpit writes per-deployment bot config JSON inside the data
# volume. Pinned — change only if you also change the volume mount.
KAI_CONFIGS_DIR=data/configs/cockpit

# Log directory (in-container). Defaults into the data volume.
KAI_LOG_DIR=/app/data/logs

# Auto-approve login requests (optional). When true, magic links are minted
# and sent immediately when a user requests access — no manual CLI approval
# needed. Leave unset/false to require `kai cockpit request approve`.
# KAI_COCKPIT_AUTO_APPROVE_LOGIN=true

# Test harness flag (optional). When set, the cockpit skips startup
# reconciliation of deployments — for integration tests only.
# KAI_COCKPIT_TESTING=true

# Port range the cockpit allocates per-user WAHA webhook listeners from.
# Purely internal to the compose network — no host port publishing needed.
KAI_WAHA_WEBHOOK_PORT_RANGE=8100-8199

# --- Outbound email: cockpit's own magic-link relay (mailer.py) --------------
# Defaults to the local Mailpit dev relay (see docker-compose.yml). For
# production with Resend:
#   KAI_SMTP_HOST=smtp.resend.com
#   KAI_SMTP_PORT=587
#   KAI_SMTP_FROM=hello@meetk.ai
#   KAI_SMTP_USER=resend
#   KAI_SMTP_PASSWORD=re_your_api_key
# When KAI_SMTP_HOST is unset entirely, the mailer prints links to stdout.
KAI_SMTP_HOST=mailpit
KAI_SMTP_PORT=1025
KAI_SMTP_FROM=support@meetk.ai
# KAI_SMTP_USER=resend
# KAI_SMTP_PASSWORD=re_your_api_key

# --- Credential encryption (required to save any credential connection) -------
# Derives the Fernet key that encrypts credential-connection secrets at rest.
# Generate with: openssl rand -hex 32
# Distinct from KAI_COCKPIT_SECRET (session signing) and KAI_WAHA_HMAC_KEY
# (WAHA webhook HMAC).
KAI_CREDENTIAL_ENCRYPTION_KEY=change-me-openssl-rand-hex-32
# Active encryption-key version. Bump via `kai cockpit rotate-credential-key`
# to rotate the encryption key without changing KAI_CREDENTIAL_ENCRYPTION_KEY.
KAI_CREDENTIAL_KEY_VERSION=v1

# --- WAHA connection (cockpit -> waha container) ------------------------------
# In-network compose values — do NOT use a host IP or public address; these
# resolve inside the docker network.
KAI_WAHA_URL=http://waha:3000
# Must match WAHA_API_KEY below (the waha container's own key).
KAI_WAHA_API_KEY=your-waha-api-key
# HMAC key for webhook verification + the operator /tell route (required).
KAI_WAHA_HMAC_KEY=random-hmac-key-for-waha-settings-validation
# Hostname WAHA calls back into for webhooks. In compose this is the cockpit
# service name; on a bare-metal/custom deploy set it to a reachable host/IP.
KAI_WAHA_WEBHOOK_PUBLIC_HOST=cockpit

# --- WAHA media/tuning (WahaSettings, all optional with defaults) ------------
# These are normally left at defaults; uncomment to tune. The per-deployment
# vars (KAI_WAHA_SESSION, KAI_WAHA_WEBHOOK_HOST/PATH/PORT) are injected at
# runtime by the cockpit, NOT set here.
# KAI_WAHA_HMAC_ALGORITHM=sha512
# KAI_WAHA_WHISPER_LANGUAGE=auto
# KAI_WAHA_WHISPER_SERVER_HOST=127.0.0.1
# KAI_WAHA_WHISPER_SERVER_PORT=8787
# KAI_WAHA_WHISPER_SERVER_THREADS=4
# KAI_WAHA_WHISPER_MODEL_PATH=models/whisper/ggml-base.bin
# KAI_WAHA_KOKORO_ENABLED=true
# KAI_WAHA_KOKORO_SERVER_HOST=127.0.0.1
# KAI_WAHA_KOKORO_SERVER_PORT=8788
# KAI_WAHA_KOKORO_MODEL_PATH=models/kokoro/kokoro-v1.0.int8.onnx
# KAI_WAHA_KOKORO_VOICES_PATH=models/kokoro/voices-v1.0.bin
# KAI_WAHA_KOKORO_VOICE=af_heart
# KAI_WAHA_KOKORO_LANG=
# KAI_WAHA_KOKORO_SPEED=1.0
# KAI_WAHA_KOKORO_MAX_CHARS=300
# KAI_WAHA_MEDIA_READY_TIMEOUT=30.0

# --- LLM configuration (core, global — never per-user) ------------------------
KAI_LLM_API_BASE=https://api.openai.com/v1
KAI_LLM_API_KEY=sk-your-api-key
KAI_LLM_MODEL=gpt-4o-mini
# Enable thinking/reasoning blocks in LLM responses (where the model supports it).
# KAI_LLM_ENABLE_THINKING=false

# --- Agent / logging (core, global) ------------------------------------------
KAI_AGENT_HISTORY_FOLDER=data
# KAI_AGENT_MAX_HISTORY_MESSAGES=100
# KAI_AGENT_MAX_HISTORY_CHARS=12000
# KAI_AGENT_MAX_CONVERSATIONS=256
# KAI_AGENT_LANGUAGE=English
# KAI_AGENT_LANGUAGE_EXPLICIT=false
# KAI_TASKS_ENABLED=true
# KAI_TASKS_POLL_INTERVAL_SECONDS=5.0
# tasks_folder is resolved against the bot's package dir (not CWD) when
# relative, so it MUST be absolute to land inside the data volume.
# KAI_TASKS_FOLDER=/app/data

# --- Brain (LightRAG + crawl4ai) — optional ----------------------------------
# The brain_query tool is only registered when KAI_BRAIN_BASE_URL and
# KAI_BRAIN_LIGHTRAG_API_KEY are both set. base_url/lightrag_api_key are
# shared across all users (one lightrag container); workspace/instruction/
# mandatory are per-user and normally injected by the cockpit deployment,
# not set here.
KAI_BRAIN_BASE_URL=http://lightrag:9621
KAI_BRAIN_LIGHTRAG_API_KEY=your-lightrag-api-key
KAI_BRAIN_CRAWLER_URL=http://crawl4ai:11235
KAI_BRAIN_CRAWL4AI_TOKEN=your-crawl4ai-token
# KAI_BRAIN_WORKSPACE=default
# KAI_BRAIN_INSTRUCTION=one trigger per line, e.g.:
#   product pricing questions
#   how to do X from section Y
# KAI_BRAIN_MANDATORY=false
# KAI_BRAIN_MANDATORY_TEMPERATURE=0.0
# KAI_BRAIN_CRAWL_MAX_DEPTH=1
# KAI_BRAIN_CRAWL_MAX_PAGES=25

# --- SMTP tool (agent email sending) — per-operator, injected by the cockpit --
# Distinct from KAI_SMTP_* above (the cockpit's own login-link relay). The
# cockpit injects these at bot start when the operator configures an SMTP
# connection and enables the email tool on a deployment; you normally don't
# set them here.
# KAI_SMTP_TOOL_HOST=smtp.example.com
# KAI_SMTP_TOOL_PORT=587
# KAI_SMTP_TOOL_USER=user
# KAI_SMTP_TOOL_PASSWORD=password
# KAI_SMTP_TOOL_FROM=user@example.com
# KAI_SMTP_TOOL_USE_TLS=true
# KAI_SMTP_TOOL_INSTRUCTION=one trigger per line

# --- SQL tool (agent database query) — per-operator, injected by the cockpit --
# KAI_SQL_DSN=postgresql://user:pass@host/db
# KAI_SQL_INSTRUCTION=one trigger per line
# KAI_SQL_ROW_LIMIT=100

# --- Email bot tuning — per-deployment, injected by the cockpit at start ------
# KAI_EMAIL_VISION is set to "1" by the cockpit when the deployment's image
# feature flag is on (enables downloading + vision-processing image attachments).
# KAI_EMAIL_MAX_ATTACHMENT_BYTES caps downloaded attachment size (default 10 MB);
# larger downloads are skipped.
# KAI_EMAIL_MAX_ATTACHMENT_BYTES=10485760

###############################################################################
# WAHA container (devlikeapro/waha) — read via compose ${VAR} interpolation.
###############################################################################
WAHA_API_KEY=your-waha-api-key
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change-me
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=change-me
WAHA_DASHBOARD_ENABLED=True
WHATSAPP_SWAGGER_ENABLED=True
WHATSAPP_DEFAULT_ENGINE=WEBJS
WAHA_NAMESPACE=all
# WAHA's own base URL (in-network hostname:port, same as KAI_WAHA_URL).
WAHA_BASE_URL=http://waha:3000
WAHA_LOG_FORMAT=JSON
WAHA_LOG_LEVEL=debug
WAHA_PRINT_QR=False
WAHA_MEDIA_STORAGE=LOCAL
WHATSAPP_FILES_LIFETIME=0
WHATSAPP_FILES_FOLDER=/app/.media
WHATSAPP_API_SCHEMA=http
WHATSAPP_API_HOSTNAME=localhost
WHATSAPP_API_PORT=3000
WAHA_APPS_ENABLED=True
# Redis used by the waha container.
REDIS_URL=redis://:redis@redis:6379

###############################################################################
# LightRAG + crawl4ai + OpenRouter (Brain containers)
###############################################################################
# One shared OpenRouter key covers LLM + embedding + rerank for the shared
# lightrag container; reuse the same key value for KAI_LLM_API_KEY above when
# the agent's LLM also routes through OpenRouter.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# LightRAG reads the unprefixed names; docker-compose maps LIGHTRAG_* -> them.
LIGHTRAG_LLM_MODEL=mistralai/ministral-3b-2512
LIGHTRAG_EMBEDDING_MODEL=perplexity/pplx-embed-v1-4b
LIGHTRAG_RERANK_MODEL=cohere/rerank-4-fast
LIGHTRAG_LLM_BINDING_HOST=https://openrouter.ai/api/v1
LIGHTRAG_EMBEDDING_BINDING_HOST=https://openrouter.ai/api/v1
LIGHTRAG_RERANK_BINDING_HOST=https://openrouter.ai/api/v1/rerank

# Build-time pin for whisper.cpp (vendors/whisper.py). Rarely changed.
# KAI_WHISPER_VERSION=latest
